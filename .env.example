# BreadControl - Variables de entorno (Plantilla de ejemplo)
# IMPORTANTE: Copia este archivo como '.env' en la raíz de tu proyecto y configura los valores correspondientes.
# NO usar paréntesis ni caracteres especiales en este archivo.

# SendGrid - Correo transaccional
SENDGRID_API_KEY=tu_api_key_aqui
SENDGRID_FROM=no-reply@tu-dominio.com
SENDGRID_FROM_NOMBRE=BreadControl

# Base de datos
DB_HOST=127.0.0.1
DB_NAME=panaderia_bd
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Aplicacion
APP_URL=http://localhost/panaderia
APP_NAME=BreadControl
APP_ENV=local

# APIs externas
API_OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast

# SMTP - Configuración para envío de correo (opcional si se usa SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_app
SMTP_FROM=no-reply@tu-dominio.com

# Google OAuth - Portal de clientes (Login social)
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
